# =============================================================================
# Research Foundry environment template
# =============================================================================
# This file (.env.example) is a COMMITTED template with PLACEHOLDER values only.
#
# Real environment files are PER-PROFILE and are GITIGNORED. NEVER commit them:
#   .env.personal   -> personal_research / public_research / personal_meatywiki
#   .env.work       -> work_internal_research / approved_work_tools (profile flag)
#   .env.client     -> explicit_client_authorized_research (human review required)
#
# Copy this template to the appropriate per-profile file and fill in real values:
#   cp .env.example .env.personal
#
# Each key profile (see config/governance.yaml -> key_profiles) loads exactly one
# of the above env files. Keys provisioned for one profile MUST NOT be reused for
# another (enforced by governance policy_rules).
# =============================================================================

# -----------------------------------------------------------------------------
# Provider API keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=replace-me-anthropic-key
OPENAI_API_KEY=replace-me-openai-key
OPENROUTER_API_KEY=replace-me-openrouter-key
TAVILY_API_KEY=replace-me-tavily-search-key

# -----------------------------------------------------------------------------
# Router / model-profile bindings (see spec 8.3 LiteLLM proxy)
# Each logical model name is backed by a (model, api_key) pair resolved here.
# Values are placeholders; set real model identifiers and keys per profile.
# -----------------------------------------------------------------------------

# rf-extract  -> cheap extraction tier
RF_EXTRACT_MODEL=replace-me-extract-model-id
RF_EXTRACT_API_KEY=replace-me-extract-api-key

# rf-verify   -> balanced verification tier
RF_VERIFY_MODEL=replace-me-verify-model-id
RF_VERIFY_API_KEY=replace-me-verify-api-key

# rf-synthesize -> deep synthesis tier
RF_SYNTH_MODEL=replace-me-synth-model-id
RF_SYNTH_API_KEY=replace-me-synth-api-key

# -----------------------------------------------------------------------------
# LiteLLM proxy / router infrastructure (see spec 8.3)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
LITELLM_MASTER_KEY=replace-me-litellm-master-key

# -----------------------------------------------------------------------------
# Integration clients (bidirectional — Phase 0+)
# Override the compiled-in default base URLs if the services run elsewhere.
# -----------------------------------------------------------------------------

# ARC (Agent Review Council) — local by default; usually no auth needed
ARC_BASE_URL=http://127.0.0.1:8910

# IntentTree — bearer token is OPTIONAL; leave blank for unauthenticated use
INTENTTREE_BASE_URL=http://localhost:8000
INTENTTREE_API_TOKEN=replace-me-intenttree-bearer-token
