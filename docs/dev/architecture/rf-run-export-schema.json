{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rf-run-export-schema.json",
  "title": "RFRunExport",
  "description": "Formal JSON Schema for the denormalized run.json contract emitted by `rf run export --json`. Schema version 1.6 (FR-13) populates writebacks.reviewer_notes/required_fix from the council review packet and adds typed writebacks.previews[] candidate content, on top of schema 1.5's optional claim persistent_references, the schema 1.4 report anchors, AOS correlation IDs, and RF native aliases. All new/additive fields are optional/nullable for backwards compatibility with pre-migration run.json documents.",
  "type": "object",
  "required": ["schema_version", "run_id", "status_derived", "claims"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Export contract version. '1.6' populates writebacks reviewer_notes/required_fix/previews[]; '1.5' adds optional claim persistent_references; '1.4' adds report_anchors and AOS correlation IDs; '1.3' fully populates context; '1.2' adds metadata enrichment fields; '1.1' added report_draft; '1.0' is the initial frozen contract.",
      "examples": ["1.6", "1.5", "1.4", "1.3", "1.2", "1.1", "1.0"]
    },
    "rf_schema_version": {
      "type": "string",
      "description": "Machine-readable contract version stamped on export_run() output (RFUP-4 machine contract). Mirrors schema_version for consumers keying off the rf_ prefix."
    },
    "run_id": {
      "type": "string",
      "description": "Canonical run identifier (e.g. rf_run_20260613_...).",
      "pattern": "^rf_run_"
    },
    "intent_id": {
      "type": ["string", "null"],
      "description": "Intent document ID. Null when intent artifact is absent.",
      "nullable": true
    },
    "aos_run_uuid": {
      "type": ["string", "null"],
      "description": "Optional AOS run UUID stamped by the Operator or AOS launcher. Null/absent for native RF runs without AOS metadata.",
      "format": "uuid",
      "nullable": true
    },
    "aos_session_uuid": {
      "type": ["string", "null"],
      "description": "Optional AOS harness/session UUID. Null/absent when the RF run was not launched from an AOS-controlled session.",
      "format": "uuid",
      "nullable": true
    },
    "aos_feature_uuid": {
      "type": ["string", "null"],
      "description": "Optional AOS feature/initiative UUID. Null/absent when no parent feature correlation is known.",
      "format": "uuid",
      "nullable": true
    },
    "aos_artifact_uuid": {
      "type": ["string", "null"],
      "description": "Optional AOS artifact UUID for the RF run/export artifact. Null/absent when no artifact correlation is known.",
      "format": "uuid",
      "nullable": true
    },
    "aos_trace_uuid": {
      "type": ["string", "null"],
      "description": "Optional AOS trace UUID for a multi-hop workflow root. Null/absent for standalone runs.",
      "format": "uuid",
      "nullable": true
    },
    "native_aliases": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "type": ["string", "null"] },
          "properties": {
            "rf_run_id": {
              "type": "string",
              "description": "Native Research Foundry run ID alias. The top-level run_id remains canonical."
            }
          }
        },
        { "type": "null" }
      ],
      "description": "Native RF alias metadata for resolver lookups. Contains IDs only, never prompt/response bodies or private paths.",
      "nullable": true
    },
    "created_at": {
      "type": ["string", "null"],
      "description": "ISO-8601 timestamp from run.yaml. Null when run.yaml is absent.",
      "nullable": true
    },
    "status_derived": {
      "type": "string",
      "description": "Derived run status (authoritative). Computed from on-disk artifacts, never from run.yaml.status.",
      "enum": [
        "planned",
        "sources_ingested",
        "extracted",
        "claim_mapped",
        "synthesized",
        "verified",
        "published"
      ]
    },
    "status_raw": {
      "type": ["string", "null"],
      "description": "Verbatim run.yaml.status (may be stale — use status_derived for display).",
      "nullable": true
    },
    "sensitivity": {
      "type": ["string", "null"],
      "description": "Run-level sensitivity label. Absent or null treated as 'public' (safe to render).",
      "enum": ["public", "personal", "work_sensitive", "client_sensitive", null],
      "nullable": true
    },
    "sensitivity_threshold": {
      "type": ["string", "null"],
      "description": "Active viewer threshold. Evidence above this level is redacted in claims[].sources.",
      "enum": ["public", "personal", "work_sensitive", "client_sensitive", null],
      "nullable": true
    },
    "claim_counts": {
      "oneOf": [
        { "$ref": "#/$defs/RFClaimCounts" },
        { "type": "null" }
      ],
      "description": "Aggregated claim count statistics. Null when claim ledger is absent.",
      "nullable": true
    },
    "verification": {
      "oneOf": [
        { "$ref": "#/$defs/RFVerification" },
        { "type": "null" }
      ],
      "description": "Verification block from reviews/verification.yaml. Null when absent.",
      "nullable": true
    },
    "governance": {
      "oneOf": [
        { "$ref": "#/$defs/RFGovernanceBlock" },
        { "type": "null" }
      ],
      "description": "Governance block from evidence_bundle. Null when absent.",
      "nullable": true
    },
    "timeline": {
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/RFTimelineEvent" },
      "description": "Telemetry/run_trace.jsonl events. Null or empty when trace is absent.",
      "nullable": true
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/RFClaim" },
      "description": "The denormalized claim graph. Each claim carries its resolved sources. Non-null (may be empty array when no ledger exists)."
    },
    "artifact_schema_versions": {
      "oneOf": [
        { "$ref": "#/$defs/RFArtifactSchemaVersions" },
        { "type": "null" }
      ],
      "description": "Per-artifact schema_version pins (OQ-7). Null when artifacts are absent.",
      "nullable": true
    },
    "report_draft": {
      "type": ["string", "null"],
      "description": "Verbatim Markdown of the synthesized report. Null when neither report_draft.md nor report_final.md exists. No sensitivity redaction applied (R9 boundary is claims[].sources[].quote/summary).",
      "nullable": true
    },
    "report_anchors": {
      "oneOf": [
        { "type": "array", "items": { "$ref": "#/$defs/RFReportAnchorBlock" } },
        { "type": "null" }
      ],
      "description": "AST-derived report block/paragraph anchors + claim spans (schema 1.4, P2 Wave A/D7-D8). Null when report_draft is null. Carries no paragraph prose — hashes, slugs, and integer offsets only — so it introduces no new sensitivity-redaction surface.",
      "nullable": true
    },
    "context": {
      "oneOf": [
        { "$ref": "#/$defs/RFRunContextSummary" },
        { "type": "null" }
      ],
      "description": "Optional v2 context stack (routing decision, research brief, swarm plan). Absent in schema 1.0/1.1 exports.",
      "nullable": true
    },
    "writebacks": {
      "oneOf": [
        { "$ref": "#/$defs/RFRunWritebacksSummary" },
        { "type": "null" }
      ],
      "description": "Optional v2 writeback summary. Absent in schema 1.0/1.1 exports.",
      "nullable": true
    },
    "linked_projects": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "List of project slugs this run is linked to. Derived from backlog idea.suggested_project at run creation or via backfill. Null/absent on pre-migration runs (schema < 1.2). Consumers must use optional access.",
      "nullable": true
    },
    "category": {
      "type": ["string", "null"],
      "description": "Research pillar / category string. Derived from backlog idea.pillar. Examples: 'AI Engineering', 'Frontend Tooling'. Null/absent on pre-migration runs.",
      "nullable": true
    },
    "tags": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "List of topic tags. Derived from backlog idea.tags or set explicitly at run creation. Null/absent on pre-migration runs.",
      "nullable": true
    },
    "backlog_idea_ref": {
      "type": ["string", "null"],
      "description": "Backlog idea ID in RIB-NNN format (e.g. 'RIB-042'). References an entry in backlog/research_idea_backlog.yaml. Null when run was not created from a backlog idea.",
      "pattern": "^RIB-\\d+$",
      "nullable": true
    },
    "backlog_idea_id": {
      "type": ["string", "null"],
      "description": "Reverse slug of the backlog idea (matches idea.id field in the backlog YAML). Provided for stable cross-referencing. Null when backlog_idea_ref is null.",
      "nullable": true
    },
    "title": {
      "type": ["string", "null"],
      "description": "Human-readable title derived from the report_draft frontmatter title: key, or a slug-humanized string when frontmatter title is absent. Added in schema_version 1.1. Absent in older cached run.json files.",
      "nullable": true
    },
    "cost_usd": {
      "type": ["number", "null"],
      "description": "Actual or budgeted cost of the run in USD. Sourced from run.yaml.profile.max_cost_usd. Null when no profile block is present (pre-enrichment runs).",
      "nullable": true
    },
    "model_profiles": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "max_cost_usd":                 { "type": ["number", "null"] },
            "extraction_model_profile":     { "type": ["string", "null"] },
            "synthesis_model_profile":      { "type": ["string", "null"] },
            "verification_model_profile":   { "type": ["string", "null"] },
            "max_runtime_minutes":          { "type": ["number", "null"] },
            "freshness_days":               { "type": ["number", "null"] }
          }
        },
        { "type": "null" }
      ],
      "description": "Model and resource profile settings for the run. Sourced from run.yaml.profile. Null when profile absent.",
      "nullable": true
    },
    "source_count_by_type": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        { "type": "null" }
      ],
      "description": "Count of source cards by source_type (e.g. {official_doc: 3, paper: 1}). Aggregated from all source cards in the run's sources/ directory. Null when no source cards are present.",
      "nullable": true
    },
    "retrieval": {
      "oneOf": [
        { "$ref": "#/$defs/RFRunRetrievalSummary" },
        { "type": "null" }
      ],
      "description": "CARP (catalog-assisted-research-planning) additive block (CARP-5.3). Read directly from the run's research_evidence_plan.yaml — the sole authoritative source for the coverage/selection decision (docs/dev/architecture/carp-contract-freeze.md §4.1), never from search_run.yaml's non-authoritative mirror. Null — never a zero-filled placeholder — when no evidence plan was ever built for this run (the disabled-policy v1 default, and every legacy/pre-CARP run).",
      "nullable": true
    }
  },
  "$defs": {
    "RFPersistentReferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_edition_id": { "type": ["string", "null"] },
        "passage_id": { "type": ["string", "null"] },
        "source_assertion_id": { "type": ["string", "null"] },
        "assertion_version": { "type": ["integer", "null"], "minimum": 1 },
        "canonical_claim_id": { "type": ["string", "null"] },
        "canonical_claim_version": { "type": ["integer", "null"], "minimum": 1 },
        "inference_id": { "type": ["string", "null"] }
      }
    },
    "RFReportAnchorClaimLink": {
      "type": "object",
      "required": ["claim_id", "span_start", "span_end", "relation", "link_status"],
      "additionalProperties": false,
      "properties": {
        "claim_id":    { "type": "string" },
        "span_start":  { "type": "integer" },
        "span_end":    { "type": "integer" },
        "relation":    {
          "type": ["string", "null"],
          "enum": ["supports", "contradicts", "inferred_from", "context", null],
          "nullable": true
        },
        "link_status": {
          "type": "string",
          "enum": ["linked", "stale", "missing_claim"]
        }
      }
    },
    "RFReportAnchorBlock": {
      "type": "object",
      "required": ["block_id", "section_id", "paragraph_ordinal", "text_hash", "claim_links"],
      "additionalProperties": false,
      "properties": {
        "block_id":          { "type": "string" },
        "section_id":        { "type": ["string", "null"], "nullable": true },
        "paragraph_ordinal": { "type": "integer" },
        "text_hash":         { "type": "string" },
        "claim_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/RFReportAnchorClaimLink" }
        }
      }
    },
    "RFClaimCounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_cards":         { "type": ["integer", "null"] },
        "extraction_cards":     { "type": ["integer", "null"] },
        "claims_total":         { "type": ["integer", "null"] },
        "claims_supported":     { "type": ["integer", "null"] },
        "claims_mixed":         { "type": ["integer", "null"] },
        "claims_contradicted":  { "type": ["integer", "null"] },
        "claims_inference":     { "type": ["integer", "null"] },
        "claims_speculation":   { "type": ["integer", "null"] },
        "claims_unsupported":   { "type": ["integer", "null"] },
        "total":                { "type": ["integer", "null"] },
        "supported":            { "type": ["integer", "null"] },
        "inference":            { "type": ["integer", "null"] },
        "speculation":          { "type": ["integer", "null"] }
      }
    },
    "RFVerificationCheck": {
      "type": "object",
      "required": ["id", "severity", "status"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "severity":  { "type": "string", "enum": ["error", "warning", "info"] },
        "status":    { "type": "string", "enum": ["pass", "fail", "skip"] },
        "detail":    { "type": ["string", "null"] },
        "locations": { "type": ["array", "null"] }
      }
    },
    "RFVerification": {
      "type": "object",
      "required": ["present"],
      "additionalProperties": false,
      "properties": {
        "present":   { "type": "boolean" },
        "passed":    { "type": ["boolean", "null"] },
        "exit_code": { "type": ["integer", "null"] },
        "checks":    {
          "type": "array",
          "items": { "$ref": "#/$defs/RFVerificationCheck" }
        }
      }
    },
    "RFGovernanceBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sensitivity":             { "type": ["string", "null"], "enum": ["public", "personal", "work_sensitive", "client_sensitive", null] },
        "approved_for_writeback":  { "type": ["boolean", "null"] },
        "approved_by":             { "type": ["string", "null"] },
        "approval_timestamp":      { "type": ["string", "null"] }
      }
    },
    "RFTimelineEvent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ts":    { "type": ["string", "null"] },
        "event": { "type": ["string", "null"] },
        "stage": { "type": ["string", "null"] }
      }
    },
    "RFResolvedSource": {
      "type": "object",
      "required": ["source_card_id", "evidence_id", "relation", "resolved", "dangling"],
      "additionalProperties": true,
      "properties": {
        "source_card_id":   { "type": "string" },
        "evidence_id":      { "type": "string" },
        "relation":         { "type": "string", "enum": ["supports", "contradicts", "context"] },
        "locator":          { "type": ["string", "null"] },
        "resolved":         { "type": "boolean" },
        "dangling":         { "type": "boolean" },
        "title":            { "type": ["string", "null"] },
        "source_type": {
          "type": ["string", "null"],
          "enum": ["official_doc", "paper", "standard", "repo", "news", "blog", "book", "personal_note", "internal_doc", "other", null]
        },
        "url":              { "type": ["string", "null"] },
        "trust": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "source_rank":        { "type": ["string", "null"], "enum": ["primary", "secondary", "tertiary", "unknown", null] },
                "reliability_notes":  { "type": ["string", "null"] },
                "known_limitations":  { "type": ["array", "null"], "items": { "type": "string" } }
              }
            },
            { "type": "null" }
          ]
        },
        "usage": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "allowed_for_public_output":       { "type": ["boolean", "null"] },
                "allowed_for_work_output":         { "type": ["boolean", "null"] },
                "allowed_for_personal_meatywiki":  { "type": ["boolean", "null"] },
                "citation_required":               { "type": ["boolean", "null"] },
                "quote_limit_notes":               { "type": ["string", "null"] }
              }
            },
            { "type": "null" }
          ]
        },
        "sensitivity":       { "type": ["string", "null"], "enum": ["public", "personal", "work_sensitive", "client_sensitive", null] },
        "evidence_locator":  { "type": ["string", "null"] },
        "summary":           { "type": ["string", "null"] },
        "quote":             { "type": ["string", "null"] }
      }
    },
    "RFInferenceBasis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from_claims":        { "type": "array", "items": { "type": "string" } },
        "reasoning_summary":  { "type": ["string", "null"] }
      }
    },
    "RFReportLocation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file":         { "type": ["string", "null"] },
        "heading":      { "type": ["string", "null"] },
        "paragraph_id": { "type": ["string", "null"] }
      }
    },
    "RFClaim": {
      "type": "object",
      "required": ["claim_id", "text", "sources"],
      "additionalProperties": false,
      "properties": {
        "claim_id":          { "type": "string" },
        "text":              { "type": "string" },
        "materiality":       { "type": ["string", "null"], "enum": ["core", "background", "style", "material", null] },
        "claim_type":        { "type": ["string", "null"] },
        "status": {
          "type": ["string", "null"],
          "enum": ["supported", "mixed", "contradicted", "inference", "speculation", "unsupported", null]
        },
        "confidence":        { "type": ["string", "null"], "enum": ["low", "medium", "high", null] },
        "report_locations":  { "type": ["array", "null"], "items": { "$ref": "#/$defs/RFReportLocation" } },
        "inference_basis": {
          "oneOf": [
            { "$ref": "#/$defs/RFInferenceBasis" },
            { "type": "null" }
          ]
        },
        "persistent_references": {
          "oneOf": [
            { "$ref": "#/$defs/RFPersistentReferences" },
            { "type": "null" }
          ],
          "description": "Optional durable assertion-ledger references. Omitted entirely for legacy claim ledgers; never synthesized by export.",
          "nullable": true
        },
        "sources":           { "type": "array", "items": { "$ref": "#/$defs/RFResolvedSource" } }
      }
    },
    "RFArtifactSchemaVersions": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "null"] },
      "properties": {
        "run":             { "type": ["string", "number", "null"] },
        "evidence_bundle": { "type": ["string", "number", "null"] },
        "claim_ledger":    { "type": ["string", "number", "null"] }
      }
    },
    "RFRunContextSummary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "routing_decision": {
          "oneOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "null" }
          ]
        },
        "research_brief_md": { "type": ["string", "null"] },
        "swarm_plan": {
          "oneOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "null" }
          ]
        },
        "upstream_entities": {
          "oneOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "null" }
          ]
        }
      }
    },
    "RFWritebackTarget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name":        { "type": ["string", "null"] },
        "destination": { "type": ["string", "null"] },
        "status":      { "type": ["string", "null"] },
        "url":         { "type": ["string", "null"] }
      }
    },
    "RFRunWritebacksSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/RFWritebackTarget" }
        },
        "approved_for_writeback": { "type": ["boolean", "null"] },
        "reviewer_notes":         { "type": ["string", "null"], "description": "Schema 1.6 (FR-13). Sourced from the council review packet (reviews/council_review.yaml), not evidence_bundle.governance." },
        "required_fix":           { "type": ["string", "null"], "description": "Schema 1.6 (FR-13). Newline-joined from the council review packet's output.concerns[].required_fix entries." },
        "previews": {
          "type": ["array", "null"],
          "description": "Schema 1.6 (FR-13). One rendered entry per present writeback file; content passes through the same sensitivity redaction as every other exported text field.",
          "items": { "$ref": "#/$defs/RFWritebackPreview" }
        }
      }
    },
    "RFWritebackPreview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "filename", "content_type", "content"],
      "properties": {
        "target":       { "type": "string" },
        "filename":     { "type": "string" },
        "content_type": { "type": "string", "enum": ["markdown", "yaml"] },
        "content":      { "type": "string" }
      }
    },
    "RFRunRetrievalSummary": {
      "type": "object",
      "additionalProperties": false,
      "description": "CARP-5.3 propagation of the run's research_evidence_plan.yaml. On a fail-closed/empty-catalog denial, `metrics` carries ONLY `questions_total` — every other candidate-derived counter is dropped outright (carp-contract-freeze.md §2.4), never passed through as a zero.",
      "properties": {
        "policy": {
          "type": ["string", "null"],
          "enum": ["catalog_only", "catalog_then_discovery", null]
        },
        "evidence_plan_ref": { "type": ["string", "null"] },
        "denial_reason": {
          "type": ["string", "null"],
          "description": "Verbatim catalog_receipt.denial_reason. Non-null iff the catalog issued a fail-closed denial for the whole plan."
        },
        "metrics": {
          "type": "object",
          "additionalProperties": { "type": ["integer", "object"] },
          "description": "Verbatim pass-through of the evidence plan's own summary block when the plan is not denied; {questions_total} only when denied (see this def's own description)."
        },
        "selections": {
          "type": "array",
          "items": { "$ref": "#/$defs/RFRunRetrievalSelection" }
        }
      }
    },
    "RFRunRetrievalSelection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "question_id":       { "type": ["string", "null"] },
        "coverage_state":    { "type": ["string", "null"], "enum": ["covered", "residual", null] },
        "residual_reason":   { "type": ["string", "null"] },
        "assertion_id":      { "type": ["string", "null"], "description": "Null unless coverage_state == covered (schema-enforced on the source evidence plan)." },
        "assertion_version": { "type": ["integer", "null"], "minimum": 1 }
      }
    }
  }
}
