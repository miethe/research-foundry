# --- Generated run exports (rf run export writes run.json into run dirs; regenerated on build) ---
runs/*/run.json
runs/**/run.json

# --- Secrets & environment ---
.env
.env.*
!.env.example
*.key
*.pem
secrets/
.secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
*.so

# --- uv ---
# uv.lock is committed; caches are not
.uv-cache/

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*~

# --- Research Foundry runtime artifacts ---
# Local tool working dirs & adapter caches (runs/ is durable & committed)
.rf_cache/
*.tmp
node_modules/

# --- Local model / vector caches ---
.paperqa/
.gpt_researcher/

# Agent scratch memory (per-agent, not a deliverable)
.claude/agent-memory/

# MkDocs build output
website/site/

# Backfill migration backups (run.yaml.bak) — git history is the canonical backup
runs/**/*.bak

# --- Research Foundry data plane (tracked elsewhere, NOT in this repo) ---
# Runs, writebacks, and captured artifacts live in the SEPARATE private repo
# `research-foundry-data` (dual git-dir at /.git-data sharing this worktree).
# Clean-forward: on-disk files are preserved; only git tracking is removed here.
/runs/
/ccdash/
/iboms/
/inbox/
/intents/active/
/intents/archived/
/intents/completed/
/intents/paused/
/intenttree/
/skillmeat/
/meatywiki/
/.firecrawl/
/registries/
/reports/
# Assertion ledger (populated by `rf assertion backfill` / forward `rf ingest`; data plane)
/assertion_ledger/
# The data-plane second-repo gitdir (this repo must not see it)
/.git-data/

# --- Regenerable / runtime artifacts (kept out of the clean project repo) ---
/.rf_state/
/ai/
.claude/skills/symbols/ai/
.claude/worktrees/
